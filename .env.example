# ── Telegram ──────────────────────────────────────────────
# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# The channel to post to. Use @ChannelUsername or the numeric ID (e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=@YourChannelUsername

# ── Facebook ───────────────────────────────────────────────
# Long-lived Page Access Token — must have access to BOTH pages
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token_here

# IML Page ID (found in Page settings → About)
# IML is treated as the preferred source of truth for duplicate content
FACEBOOK_IML_PAGE_ID=your_iml_page_id_here

# IMBB Page ID
FACEBOOK_IMBB_PAGE_ID=your_imbb_page_id_here

# A secret string YOU choose — must match what you enter in the Facebook webhook dashboard
FACEBOOK_WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token

# ── Server ─────────────────────────────────────────────────
PORT=3000
