# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=@YourChannelUsername

# ── Facebook ───────────────────────────────────────────────
# Separate long-lived Page Access Tokens for each page
FACEBOOK_IML_PAGE_ACCESS_TOKEN=your_iml_page_access_token_here
FACEBOOK_IMBB_PAGE_ACCESS_TOKEN=your_imbb_page_access_token_here

# Page IDs (found in Page settings → About)
FACEBOOK_IML_PAGE_ID=your_iml_page_id_here
FACEBOOK_IMBB_PAGE_ID=your_imbb_page_id_here

# App credentials (from App Settings → Basic in Facebook Developer dashboard)
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here

# A secret string YOU choose — must match what you enter in the Facebook webhook dashboard
FACEBOOK_WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token

# ── Server ─────────────────────────────────────────────────
PORT=3000
